<?xml version="1.0" encoding="UTF-8"?>
<classpath>
	<classpathentry kind="src" path="src/main/resources"/>
	<classpathentry kind="src" path="src/main/java"/>
	<classpathentry kind="lib" path="jars/commons-codec-1.5.jar"/>
	<classpathentry kind="lib" path="jars/Complex.jar"/>
	<classpathentry kind="lib" path="jars/Convert2.0.jar"/>
	<classpathentry kind="lib" path="jars/DJEP2.4.0Minimal.jar"/>
	<classpathentry kind="lib" path="jars/FunctionChoiceBox.jar"/>
	<classpathentry kind="lib" path="jars/FunctionField.jar"/>
	<classpathentry kind="lib" path="jars/FunctionParser.jar" sourcepath="jars/FunctionParser.jar"/>
	<classpathentry kind="lib" path="jars/javabuilder.jar"/>
	<classpathentry kind="lib" path="jars/jbcl.jar"/>
	<classpathentry kind="lib" path="jars/xercesImpl.jar"/>
	<classpathentry kind="con" path="org.eclipse.jdt.launching.JRE_CONTAINER/org.eclipse.jdt.internal.debug.ui.launcher.StandardVMType/JavaSE-1.8">
		<attributes>
			<attribute name="module" value="true"/>
			<attribute name="maven.pomderived" value="true"/>
		</attributes>
	</classpathentry>
	<classpathentry kind="con" path="org.eclipse.jdt.USER_LIBRARY/libEDelaunay.dll">
		<attributes>
			<attribute name="org.eclipse.jdt.launching.CLASSPATH_ATTR_LIBRARY_PATH_ENTRY" value="CirclePack/lib"/>
		</attributes>
	</classpathentry>
	<classpathentry kind="con" path="org.eclipse.jdt.USER_LIBRARY/javaFX"/>
	<classpathentry kind="con" path="org.eclipse.m2e.MAVEN2_CLASSPATH_CONTAINER">
		<attributes>
			<attribute name="maven.pomderived" value="true"/>
		</attributes>
	</classpathentry>
	<classpathentry including="**/*.java" kind="src" output="target/test-classes" path="src/test/resources">
		<attributes>
			<attribute name="test" value="true"/>
			<attribute name="maven.pomderived" value="true"/>
			<attribute name="optional" value="true"/>
		</attributes>
	</classpathentry>
	<classpathentry kind="src" path="cdeps"/>
	<classpathentry kind="output" path="target/classes"/>
</classpath>
